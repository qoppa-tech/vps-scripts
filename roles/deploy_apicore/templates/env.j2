# API Core Environment Variables
PORT=8080
APP_ENV=deployment

# Database
DB_HOST={{ postgres_host }}
DB_PORT={{ postgres_port }}
DB_DATABASE={{ postgres_db }}
DB_USERNAME={{ postgres_user }}
DB_PASSWORD={{ postgres_password }}
DB_SCHEMA={{ postgres_schema | default('public') }}

# URLs
FRONTEND_URL={{ frontend_url | default('https://app.parlorharpia.tech') }}
LANDING_PAGE_URL={{ landing_url | default('https://landing.parlorharpia.tech') }}

# Redis
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
REDIS_USERNAME={{ redis_username | default('default') }}
REDIS_PASSWORD={{ redis_password | default('') }}
REDIS_DB={{ redis_db | default('0') }}

# JWT
JWT_SECRET={{ jwt_secret }}
JWT_ISSUER={{ jwt_issuer | default('parlor-api') }}
JWT_EXPIRATION_HOURS={{ jwt_expiration_hours | default('24') }}
JWT_REFRESH_EXPIRATION_HOURS={{ jwt_refresh_expiration_hours | default('168') }}

# Email
MAILTRAP_TOKEN={{ mailtrap_token | default('') }}
MAILTRAP_URL={{ mailtrap_url | default('https://send.api.mailtrap.io/api/send') }}

# Google OAuth
GOOGLE_CLIENT_ID={{ google_client_id | default('') }}
GOOGLE_CLIENT_SECRET={{ google_client_secret | default('') }}
GOOGLE_REDIRECT_URL={{ google_redirect_url | default('https://api.parlorharpia.tech/auth/google/callback') }}
